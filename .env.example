PORT=3000
NODE_ENV=development

OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Multi-collection (CSV). Takes priority over QDRANT_COLLECTION_NAME.
# QDRANT_COLLECTIONS=docs_padronizacao,docs_normas,docs_gerais
# QDRANT_COLLECTION_DESCRIPTIONS=Documentos de padronização,Normas técnicas,Documentos gerais

# Single collection (backward compatible, used if QDRANT_COLLECTIONS is absent)
QDRANT_COLLECTION_NAME=rag_collection

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4
