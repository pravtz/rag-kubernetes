{
  "info": {
    "name": "RAG API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleção gerada a partir da documentação da RAG API"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Verificação básica de que a API está respondendo."
      }
    },
    {
      "name": "Status da API",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/rag/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "status"]
        },
        "description": "Status operacional com verificação de dependências."
      }
    },
    {
      "name": "Readiness",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/rag/ready",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "ready"]
        },
        "description": "Probe de readiness para K8s/orquestradores."
      }
    },
    {
      "name": "Upload de PDF (collection padrão)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "",
              "description": "Arquivo PDF (máx 50 MB)"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/rag/ingest",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "ingest"]
        },
        "description": "Upload de PDF para a collection padrão."
      }
    },
    {
      "name": "Upload de PDF (collection específica)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "",
              "description": "Arquivo PDF (máx 50 MB)"
            },
            {
              "key": "collection",
              "value": "relatorio_de_custos",
              "type": "text",
              "description": "Nome da collection de destino"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/rag/ingest",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "ingest"]
        },
        "description": "Upload de PDF para uma collection específica."
      }
    },
    {
      "name": "Consulta (routing automático)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"O que é RAG?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/rag/query",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "query"]
        },
        "description": "Consulta com routing automático de collections. Resposta em streaming (text/plain)."
      }
    },
    {
      "name": "Consulta (forceCollections)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Quais são as normas?\",\n  \"forceCollections\": [\"relatorio_de_custos\"]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/rag/query",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "query"]
        },
        "description": "Consulta forçando collections específicas, ignorando o routing automático."
      }
    },
    {
      "name": "Consulta — alias /question",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"O que é RAG?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/rag/question",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "question"]
        },
        "description": "Alias para /api/rag/query."
      }
    },
    {
      "name": "Consulta — alias /pergunta",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"O que é RAG?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/rag/pergunta",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "pergunta"]
        },
        "description": "Alias para /api/rag/query."
      }
    },
    {
      "name": "Diagnósticos do Qdrant",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/rag/qdrant-info",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rag", "qdrant-info"]
        },
        "description": "Informações detalhadas sobre cada collection configurada e estado do Qdrant."
      }
    }
  ]
}
